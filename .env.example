# Backend
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# For Postgres (optional; sqlite is used if DATABASE_URL is empty)
DATABASE_URL=postgres://carbon:carbon@localhost:5432/carbon

# Production-only (when DJANGO_DEBUG=false)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
